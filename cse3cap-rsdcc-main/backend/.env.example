# Flask Server Configuration
PORT=5000
FLASK_HOST=0.0.0.0
FLASK_ENV=development
FLASK_DEBUG=True

# CORS Configuration
CORS_ORIGINS=http://localhost:5173

# ASCOM Alpaca Telescope Configuration (Common simulator ports: 32323 (SimScope), 11111, 8080, 5555)
ALPACA_BASE=http://localhost:32323/api/v1/telescope/0 # Your ASCOM Alpaca simulator
CLIENT_ID=1

# OpenTelemetry Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-lgtm:4317
OTEL_SERVICE_NAME=cse3cap-rsdcc
OTEL_ENVIRONMENT=development

# Weather API Configuration (ThingSpeak)
# Get these from ThingSpeak if you want weather data
THINGSPEAK_API_BASE_URL=https://api.thingspeak.com
THINGSPEAK_CHANNEL_ID=270748
THINGSPEAK_READ_API_KEY=your_read_api_key_here

CAPTURES_DIR=/data/captures